#!/usr/bin/env bash
set -euo pipefail

GTK3_DIR="$HOME/.config/gtk-3.0"
GTK4_DIR="$HOME/.config/gtk-4.0"

apply_theme() {
    local scheme theme

    scheme="$(gsettings get org.gnome.desktop.interface color-scheme | tr -d "'")"
    if [ "$scheme" = "prefer-dark" ]; then
        theme="WhiteSur-Dark"
    else
        theme="WhiteSur-Light"
    fi

    gsettings set org.gnome.desktop.interface gtk-theme "$theme"
    gsettings set org.gnome.shell.extensions.user-theme name "$theme" 2>/dev/null || true
    gsettings set org.gnome.desktop.wm.preferences button-layout 'close,minimize,maximize:'
    gsettings set org.gnome.desktop.interface gtk-decoration-layout 'close,minimize,maximize:' 2>/dev/null || true

    mkdir -p "$GTK3_DIR"
    cat > "$GTK3_DIR/settings.ini" <<EOF
[Settings]
gtk-theme-name=$theme
gtk-icon-theme-name=WhiteSur-light
gtk-cursor-theme-name=WhiteSur-cursors
gtk-font-name=Cantarell 11
gtk-decoration-layout=close,minimize,maximize:
EOF

    if [ -d "$GTK4_DIR/assets" ]; then
        rm -rf "$GTK4_DIR/windows-assets"
        ln -s assets "$GTK4_DIR/windows-assets"
    fi
}

apply_theme

if [ "${1:-}" = "--once" ]; then
    exit 0
fi

gsettings monitor org.gnome.desktop.interface color-scheme | while read -r _; do
    apply_theme
done
